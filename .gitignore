# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
mcp-servers/**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# owner-local dev environment / AI tooling — not part of the template
.claude/
CLAUDE.md
.mcp.json
.husky/
.vscode/
.github/
dockerfile
docker-compose.yml
.dockerignore
scripts/

# formatting / linting (local-only, never tracked; forks provide their own)
.prettierrc*
.prettierignore
prettier.config.*
eslint.config.*
.eslintrc*
commitlint.config.js
lint-staged.config.*

# testing (local-only, never tracked; forks provide their own)
/coverage
*.test.*
*.spec.*
__tests__/
vitest.config.*
vitest.setup.*
cypress/
cypress.config.ts
cypress.env.json
.storybook/
*storybook.log
storybook-static

# vercel
.vercel
