# Copy this file to .env.local and fill in the values for your own deployment.
# .env.local is gitignored — never commit real values.

# The password for the desktop's Admin account. The Admin sign-in
# form posts the entered password to /api/admin, which compares it here
# server-side. Leave it unset to disable Admin sign-in.
ADMIN_PASSWORD=

# Optional: mount the app under a subpath (e.g. /desktop) when serving it behind
# a rewrite zone at example.com/desktop. Leave unset to serve at the domain root.
BASE_PATH=
